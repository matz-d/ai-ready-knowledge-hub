# Copy to .env.local and fill in (see docs/setup-gcp.md).
GOOGLE_CLOUD_PROJECT=ai-ready-knowledge-hub
GOOGLE_CLOUD_LOCATION=asia-northeast1

# GCS bucket for uploaded originals (W2 walking skeleton).
KNOWLEDGE_HUB_BUCKET=your-gcs-bucket-name

# Optional: Firestore client prefers REST over gRPC (see docs/setup-gcp.md).
# FIRESTORE_PREFER_REST=true

# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
