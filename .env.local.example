# Copy to .env.local and fill in (see docs/setup-gcp.md).
GOOGLE_CLOUD_PROJECT=ai-ready-knowledge-hub
GOOGLE_CLOUD_LOCATION=asia-northeast1

# GCS bucket for uploaded originals (W2 walking skeleton).
KNOWLEDGE_HUB_BUCKET=your-gcs-bucket-name

# Optional: Firestore client prefers REST over gRPC (see docs/setup-gcp.md).
# FIRESTORE_PREFER_REST=true

# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional masker provider. Use cloud-dlp for Google Cloud Sensitive Data Protection.
# MASKER_PROVIDER=simple-rule

# Optional ADC: path to a service account JSON key. If unset, use
# `gcloud auth application-default login` (docs/setup-gcp.md). Same credential
# chain as other Google client libraries: Firestore, GCS uploads, Vertex/Gemini
# (curator), Cloud DLP when MASKER_PROVIDER=cloud-dlp, and Google Sheets/Drive
# import. Not masker-only; demo runbook often recommends an SA key for Drive.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# Optional: SA email when ADC credentials have no client_email (e.g. some
# metadata-server setups). Sheets import UI also uses this if the email cannot
# be read from the key file. Omit if your ADC JSON already includes client_email.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxxx@xxxxx.iam.gserviceaccount.com
