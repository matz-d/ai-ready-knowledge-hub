rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /auditEvents/{eventId} {
      allow create: if false; // Admin SDK は Rules 非経由なので create は実質 Admin SDK 限定
      allow read: if false; // Phase 3-D では client SDK 経路を持たない
      allow update, delete: if false; // append-only 保証
    }

    // Conversion eval — read/write exclusively via Admin SDK (Cloud Run behind IAP).
    // Client SDK has no direct access; eval rows are append-only at the adapter layer.
    match /conversion_eval/{evalId} {
      allow create: if false;
      allow read: if false;
      allow update, delete: if false;
    }

    // Feature flags — read/write exclusively via Admin SDK (Cloud Run).
    // Client SDK has no direct access; flags are served only through the
    // /api/* routes after IAP authentication.
    match /feature_flags/{flagId} {
      allow read, write: if false;
    }
  }
}
